# Copy to `.env` and fill in with values from your Supabase project
# (Project Settings → API in the Supabase dashboard).
#
# The publishable/anon key is safe to expose in the frontend — RLS enforces
# access on the database side. NEVER put the service_role key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
